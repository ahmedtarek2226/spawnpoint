# Port the dashboard listens on
DASHBOARD_PORT=3000

# Optional: CurseForge integration — unlocks the mod browser and modpack installer.
# Get a free API key at: https://console.curseforge.com/
#
# RECOMMENDED: create a file called "curseforge.key" in your data directory and
# paste your API key there (one line, no quotes). This avoids Docker Compose
# mangling the $ characters that CurseForge keys contain.
#
# Alternatively set the env var below, but you must escape every $ as $$:
# CURSEFORGE_API_KEY=$$2a$$10$$rest-of-your-key-here
# REQUIRED: Absolute path on the HOST machine where server data is stored.
# This is bind-mounted into the dashboard container AND used when creating
# individual Minecraft server containers, so it MUST be absolute.
#
# Example:
#   HOST_DATA_DIR=/home/youruser/spawnpoint/data
#
# If unset, defaults to <directory where you run docker compose>/data
# HOST_DATA_DIR=/home/youruser/spawnpoint/data

# Optional: protect the dashboard with a username and password.
# If left unset, the dashboard is accessible without authentication.
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=your-password-here

# Optional: allowed CORS origins (comma-separated), or * for all.
# If unset, CORS is disabled (same-origin only — recommended).
# Only needed if accessing the API from a different origin (e.g. during development).
# CORS_ORIGIN=https://example.com
